model RefreshToken {
    id        String   @id @default(uuid())
    userId    String
    token     String   @unique @db.VarChar(500)
    expiresAt DateTime
    revoked   Boolean  @default(false)
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
    @@map("refresh_tokens")
}
